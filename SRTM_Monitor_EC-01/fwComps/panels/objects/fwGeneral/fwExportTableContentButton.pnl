    <script name="Clicked" isEscaped="1"><![CDATA[#uses &quot;fwGeneral/fwScreenShot.ctl&quot;

main()
{
  dyn_string exceptionInfo;
  fwScreenShot_exportTableContentUserMenu( $tableToExport, exceptionInfo);
