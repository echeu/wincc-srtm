  <shape Name="PUSH_BUTTON_CREATE" shapeType="PUSH_BUTTON" layerId="0">
   <properties>
    <prop name="serialId">13</prop>
    <prop name="Type"></prop>
    <prop name="RefPoint">346 330</prop>
    <prop name="Enable">False</prop>
    <prop name="Visible">True</prop>
    <prop name="ForeColor">_ButtonText</prop>
    <prop name="BackColor">_Button</prop>
    <prop name="TabOrder">13</prop>
    <prop name="ToolTipText">
     <prop name="en_US.utf8"></prop>
    </prop>
    <prop name="layoutAlignment">AlignNone</prop>
    <prop name="snapMode">Point</prop>
    <prop name="Font">
     <prop name="en_US.utf8">MS Shell Dlg 2,-1,11,5,50,0,0,0,0,0</prop>
    </prop>
    <prop name="Location">346 325</prop>
    <prop name="Size">77 23</prop>
    <prop name="BorderStyle">Styled</prop>
    <prop name="Text">
     <prop name="en_US.utf8">Create</prop>
    </prop>
   </properties>
   <events>
    <script name="Clicked" isEscaped="1"><![CDATA[main(mapping event)
{
  string sCopyServer, sCopySubscription, sNewServer, sNewSubscription;


  if( RADIO_BOX_SERVER.number() == 0 )
  {
    sCopyServer = &quot;_OPCUA_TOOLS&quot;;
  }
  else
  {
    sCopyServer = COMBO_BOX_OLD_SERVER.selectedText();
  }
  sNewServer = TEXT_FIELD_NEW_SERVER_NAME.text();


  switch( RADIO_BOX_SUBSCRIPTION.number() )
  {
    case 0:
      sCopySubscription = &quot;_OPCUA_TOOLS_DEFAULT&quot;;
      sNewSubscription  = TEXT_FIELD_NEW_SUBSCRIPTION_NAME.text();
      break;

    case 1:
      sCopySubscription = &quot;&quot;;
      sNewSubscription  = &quot;&quot;;
      break;

    case 2:
      sCopySubscription = COMBO_BOX_OLD_SUBSCRIPTION.selectedText();
      sNewSubscription  = TEXT_FIELD_NEW_SUBSCRIPTION_NAME.text();
      break;

    default:
      break;
  }


  PanelOffReturn(makeDynFloat(1),
                 makeDynString(SPIN_BUTTON_DRIVER.value(),
                               sNewServer,
                               sCopyServer,
                               sNewSubscription,
                               sCopySubscription));
}]]></script>
   </events>
  </shape>
