      COMBO_BOX_OLD_SERVER.enabled(FALSE);
      break;

    case 1: // OPC UA Server combo box
      COMBO_BOX_OLD_SERVER.enabled(TRUE);
      break;

    default:
      COMBO_BOX_OLD_SERVER.enabled(FALSE);
      COMBO_BOX_OLD_SUBSCRIPTION.enabled(FALSE);
      PUSH_BUTTON_CREATE.enabled(FALSE);
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error selected option in RADIO_BOX_SERVER unknown, please report this issue to icecontrols.support@cern.ch&quot;, &quot;&quot;);
      fwExceptionHandling_display(exceptionInfo);
      return;
  }

}]]></script>
