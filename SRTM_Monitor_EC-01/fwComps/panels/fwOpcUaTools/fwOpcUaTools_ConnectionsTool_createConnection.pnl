void enableShapes(bool bEnable)
{
  COMBO_BOX_OLD_SERVER.enabled(bEnable);
  COMBO_BOX_OLD_SUBSCRIPTION.enabled(bEnable);
  TEXT_FIELD_NEW_SERVER_NAME.enabled(bEnable);
  TEXT_FIELD_NEW_SUBSCRIPTION_NAME.enabled(bEnable);
  PUSH_BUTTON_CREATE.enabled(bEnable);
  SPIN_BUTTON_DRIVER.enabled(bEnable);
}




void animateCreate()
{
  bool bExistsServer, bExistsSubscription;
  int iOptionServer, iOptionSubscription;
  string sServerName, sSubscriptionName;

  getMultiValue(&quot;TEXT_FIELD_NEW_SERVER_NAME&quot;,       &quot;text&quot;,   sServerName,
                &quot;RADIO_BOX_SERVER&quot;,                 &quot;number&quot;, iOptionServer,
                &quot;TEXT_FIELD_NEW_SUBSCRIPTION_NAME&quot;, &quot;text&quot;,   sSubscriptionName,
                &quot;RADIO_BOX_SUBSCRIPTION&quot;,           &quot;number&quot;, iOptionSubscription);

  bExistsServer       = dpExists(sServerName);
  bExistsSubscription = dpExists(sSubscriptionName);

  if( bExistsServer                                                                 ||
      bExistsSubscription                                                           ||
      (sServerName == &quot;&quot;)                                                           ||
      ((iOptionSubscription != 1) &amp;&amp; (sSubscriptionName == &quot;&quot;))                     ||
      ((iOptionServer == 1)       &amp;&amp; (COMBO_BOX_OLD_SERVER.itemCount() == 0))       ||
      ((iOptionSubscription ==2)  &amp;&amp; (COMBO_BOX_OLD_SUBSCRIPTION.itemCount() == 0))   )
  {
    PUSH_BUTTON_CREATE.enabled(FALSE);
    return;
  }
  else
  {
    PUSH_BUTTON_CREATE.enabled(TRUE);
  }

}
]]></script>
  <script name="Initialize" isEscaped="1"><![CDATA[main()
{
  initialize_OpcUaConnections();
  initialize_OpcUaSubscriptions();
  animateCreate();
}





void initialize_OpcUaConnections()
{
  int iLen, iLoop;
  dyn_string dsAllServers, dsServers;

  dsAllServers = dpNames(getSystemName() + &quot;*&quot;, &quot;_OPCUAServer&quot;);
  iLen         = dynlen(dsAllServers);

  if( iLen &gt; 0 )
  {
    // Remove redundant connections
    for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
    {
      // Redundant connection = CONNECTION + _2
      if( strpos(dsAllServers[iLoop], &quot;_2&quot;) != (strlen(dsAllServers[iLoop])-2) )
      {
        dynAppend(dsServers, dpSubStr(dsAllServers[iLoop], DPSUB_DP));
      }
    }
  }
  dynSort(dsServers);

  COMBO_BOX_OLD_SERVER.deleteAllItems();
  COMBO_BOX_OLD_SERVER.items(dsServers);
  COMBO_BOX_OLD_SERVER.selectedPos(1);
}






void initialize_OpcUaSubscriptions()
{
  int iLen, iLoop;
  dyn_string dsAllSubscriptions, dsSubscriptions;


  dsAllSubscriptions = dpNames(getSystemName() + &quot;*&quot;, &quot;_OPCUASubscription&quot;);
  iLen               = dynlen(dsAllSubscriptions);


  if( iLen &gt; 0 )
  {
    // Remove redundant subscriptions
    for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
    {
      // Redundant subscription = SUBSCRIPTION + _2
      if( strpos(dsAllSubscriptions[iLoop], &quot;_2&quot;) != (strlen(dsAllSubscriptions[iLoop])-2) )
      {
        dynAppend(dsSubscriptions, dpSubStr(dsAllSubscriptions[iLoop], DPSUB_DP));
      }
    }
  }
  dynSort(dsSubscriptions);

  COMBO_BOX_OLD_SUBSCRIPTION.deleteAllItems();
  COMBO_BOX_OLD_SUBSCRIPTION.items(dsSubscriptions);
  COMBO_BOX_OLD_SUBSCRIPTION.selectedPos(1);
}





]]></script>
