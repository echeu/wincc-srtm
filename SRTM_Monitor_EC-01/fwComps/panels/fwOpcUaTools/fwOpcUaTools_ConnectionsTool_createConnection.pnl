    <prop name="TabOrder">11</prop>
    <prop name="ToolTipText">
     <prop name="en_US.utf8"></prop>
    </prop>
    <prop name="layoutAlignment">AlignNone</prop>
    <prop name="snapMode">Point</prop>
    <prop name="Font">
     <prop name="en_US.utf8">MS Shell Dlg 2,-1,11,5,50,0,0,0,0,0</prop>
    </prop>
    <prop name="Location">211 227</prop>
    <prop name="Size">270 21</prop>
    <prop name="BorderStyle">Normal</prop>
    <prop name="Editable">True</prop>
    <prop name="ClearButtonEnabled">False</prop>
    <prop name="TextFormat">[0s,,,AlignLeft]</prop>
    <prop name="ulcClientSideWidget">False</prop>
   </properties>
   <events>
    <script name="TextChanged" isEscaped="1"><![CDATA[main(string sNewText)
{
  string sUaServer;
  dyn_string exceptionInfo;


  // In case manual edit of the subscription, keep always the OPC UA server name + &quot;_&quot;
  sUaServer = TEXT_FIELD_NEW_SERVER_NAME.text();
  if( strpos(sNewText, sUaServer + &quot;_&quot;) != 0 )
  {
    TEXT_FIELD_NEW_SUBSCRIPTION_NAME.text(sUaServer + &quot;_&quot;);
  }

  // Check subscription name does not exist
  if( dpExists(sNewText) )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, subscription name already in use, please use another name&quot;, &quot;&quot;);
    fwExceptionHandling_display(exceptionInfo);
  }

  animateCreate();

}]]></script>
   </events>
  </shape>
