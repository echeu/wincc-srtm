    <prop name="snapMode">Point</prop>
    <prop name="Font">
     <prop name="en_US.utf8">MS Shell Dlg 2,-1,11,5,50,0,0,0,0,0</prop>
    </prop>
    <prop name="Location">246 106</prop>
    <prop name="Size">235 21</prop>
    <prop name="BorderStyle">Normal</prop>
    <prop name="Editable">True</prop>
    <prop name="ClearButtonEnabled">False</prop>
    <prop name="TextFormat">[0s,,,AlignLeft]</prop>
    <prop name="ulcClientSideWidget">False</prop>
   </properties>
   <events>
    <script name="TextChanged" isEscaped="1"><![CDATA[main(string sNewText)
{
  string sOpcUaServerDp;
  dyn_string exceptionInfo;


  if( sNewText != &quot;&quot; )
  {
    strreplace(sNewText, &quot; &quot;, &quot;&quot;);
    TEXT_FIELD_NEW_SERVER_NAME.text(sNewText);
    TEXT_FIELD_NEW_SUBSCRIPTION_NAME.text(sNewText + &quot;_&quot;);
    TEXT_FIELD_NEW_SUBSCRIPTION_NAME.enabled(TRUE);

    if( strpos(sNewText, &quot;_&quot;) != 0 )
    {
      TEXT_FIELD_NEW_SERVER_NAME.text(&quot;_&quot; + sNewText);
      TEXT_FIELD_NEW_SUBSCRIPTION_NAME.text(sNewText + &quot;_&quot;);
      TEXT_FIELD_NEW_SUBSCRIPTION_NAME.enabled(TRUE);
    }


    sOpcUaServerDp = TEXT_FIELD_NEW_SERVER_NAME.text();
    sOpcUaServerDp = dpSubStr(sOpcUaServerDp, DPSUB_DP);
    if( sOpcUaServerDp != &quot;&quot; )
    {
      if( dpExists(sOpcUaServerDp)       ||
          dpExists(sOpcUaServerDp + &quot;_2&quot;)  )
      {
        fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, OPC UA server connection already exists: &quot; + sOpcUaServerDp + &quot; / &quot; + sOpcUaServerDp + &quot;_2. Please select a new name&quot;, &quot;&quot;);
        fwExceptionHandling_display(exceptionInfo);
      }
    }
  }
  else
  {
    TEXT_FIELD_NEW_SUBSCRIPTION_NAME.text(&quot;&quot;);
    TEXT_FIELD_NEW_SUBSCRIPTION_NAME.enabled(FALSE);
    return;
  }

  animateCreate();

}
]]></script>
   </events>
