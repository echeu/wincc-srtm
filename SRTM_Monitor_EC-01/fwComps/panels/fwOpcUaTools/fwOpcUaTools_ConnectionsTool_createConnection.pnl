  <shape Name="RADIO_BOX_SUBSCRIPTION" shapeType="RADIO_BOX" layerId="0">
   <properties>
    <prop name="serialId">9</prop>
    <prop name="Type"></prop>
    <prop name="RefPoint">26 254</prop>
    <prop name="Enable">True</prop>
