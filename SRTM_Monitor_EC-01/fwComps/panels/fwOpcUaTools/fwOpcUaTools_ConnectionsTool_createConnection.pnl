     <prop name="en_US.utf8"></prop>
    </prop>
    <prop name="layoutAlignment">AlignNone</prop>
    <prop name="snapMode">Point</prop>
    <prop name="Font">
     <prop name="en_US.utf8">MS Shell Dlg 2,-1,11,5,50,0,0,0,0,0</prop>
    </prop>
    <prop name="Location">26 254</prop>
    <prop name="Size">455 64</prop>
    <prop name="Listitems">
     <prop name="Item">
      <prop name="Text">
       <prop name="en_US.utf8">Default settings: _OPCUA_TOOLS_DEFAULT</prop>
      </prop>
      <prop name="Select">True</prop>
     </prop>
     <prop name="Item">
      <prop name="Text">
       <prop name="en_US.utf8">None subscription</prop>
      </prop>
      <prop name="Select">False</prop>
     </prop>
     <prop name="Item">
      <prop name="Text">
       <prop name="en_US.utf8">Copy from</prop>
      </prop>
      <prop name="Select">False</prop>
     </prop>
    </prop>
   </properties>
   <events>
    <script name="Clicked" isEscaped="1"><![CDATA[main(int iButton)
{
  dyn_string exceptionInfo;


  switch (iButton)
  {
    case 0: // Default parameters
      COMBO_BOX_OLD_SUBSCRIPTION.enabled(FALSE);
      TEXT_FIELD_NEW_SUBSCRIPTION_NAME.enabled(TRUE);
      // Enable PUSH_BUTTON_CREATE
      if( (TEXT_FIELD_NEW_SERVER_NAME.text()       != &quot;&quot;) &amp;&amp;
          (TEXT_FIELD_NEW_SUBSCRIPTION_NAME.text() != &quot;&quot;)  )
      {
        PUSH_BUTTON_CREATE.enabled(TRUE);
      }
      else
      {
        PUSH_BUTTON_CREATE.enabled(FALSE);
      }
      break;


    case 1: // None subscription
      COMBO_BOX_OLD_SUBSCRIPTION.enabled(FALSE);
      TEXT_FIELD_NEW_SUBSCRIPTION_NAME.enabled(FALSE);
      if( TEXT_FIELD_NEW_SERVER_NAME.text() != &quot;&quot; )
      {
        PUSH_BUTTON_CREATE.enabled(TRUE);
      }
      else
      {
        PUSH_BUTTON_CREATE.enabled(FALSE);
      }
      break;


    case 2: // OPC UA Server combo box
      if( COMBO_BOX_OLD_SUBSCRIPTION.itemCount() != 0 )
      {
        COMBO_BOX_OLD_SUBSCRIPTION.enabled(TRUE);
        TEXT_FIELD_NEW_SUBSCRIPTION_NAME.enabled(TRUE);
        if( (TEXT_FIELD_NEW_SERVER_NAME.text() != &quot;&quot;)       &amp;&amp;
            (TEXT_FIELD_NEW_SUBSCRIPTION_NAME.text() != &quot;&quot;)   )
        {
          PUSH_BUTTON_CREATE.enabled(TRUE);
        }
        else
        {
          PUSH_BUTTON_CREATE.enabled(FALSE);
        }
      }
      else
      {
        COMBO_BOX_OLD_SUBSCRIPTION.enabled(FALSE);
      }
      break;


    default:
      enableShapes(FALSE);
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error selected option in RADIO_BOX_SUBSCRIPTION unknown, please report this issue to icecontrols.support@cern.ch&quot;, &quot;&quot;);
      fwExceptionHandling_display(exceptionInfo);
      return;
  }

}
]]></script>
   </events>
