  <shape Name="TEXT_FIELD_NEW_SERVER_NAME" shapeType="TEXT_FIELD" layerId="0">
   <properties>
    <prop name="serialId">6</prop>
    <prop name="Type"></prop>
    <prop name="RefPoint">246 106</prop>
    <prop name="Enable">True</prop>
