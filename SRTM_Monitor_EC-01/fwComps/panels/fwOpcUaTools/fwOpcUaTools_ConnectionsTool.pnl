    <prop name="snapMode">Point</prop>
    <prop name="Font">
     <prop name="en_US.utf8">MS Shell Dlg 2,-1,11,5,50,0,0,0,0,0</prop>
    </prop>
    <prop name="Location">57.62499999999978 628.1818181818182</prop>
    <prop name="Size">283 31</prop>
    <prop name="BorderStyle">Styled</prop>
    <prop name="Text">
     <prop name="en_US.utf8">Search DPEs to move</prop>
    </prop>
   </properties>
   <events>
    <script name="Clicked" isEscaped="1"><![CDATA[main(mapping event)
{
  bool bAddChildren, bJcopDevice, bDriversEnabled, bIncludeCommands;
  int iNumberTries, iNewOpcUaConnectionDriverNumber;
  string sDeviceDp, sDriverNumbers, sOpcUaConnectionFilter, sOpcUaSubscriptionFilter, sNewOpcUaServerConnection;
  dyn_int diDriverNumbers;
  dyn_float dfResult;
  dyn_string dsResult, dsDeviceDpes, exceptionInfo;
  dyn_dyn_anytype ddaSettings;


  bDriversEnabled = FALSE;
  iNumberTries    = 3;

  getMultiValue(&quot;CHECK_BOX_DEVICE_OPTIONS&quot;,   &quot;state&quot;,   0, bAddChildren,
                &quot;CHECK_BOX_JCOP_DEVICE&quot;,      &quot;state&quot;,   0, bJcopDevice,
                &quot;CHECK_BOX_COMMANDS&quot;,         &quot;state&quot;,   0, bIncludeCommands,
                &quot;TEXT_FIELD_DP&quot;,              &quot;text&quot;,    sDeviceDp);
  setMultiValue(//&quot;PUSH_BUTTON_JCOP&quot;,         &quot;enabled&quot;, FALSE,
                &quot;PUSH_BUTTON_NON_JCOP&quot;,       &quot;enabled&quot;, FALSE,
                &quot;CHECK_BOX_JCOP_DEVICE&quot;,      &quot;enabled&quot;, FALSE,
                &quot;CHECK_BOX_DEVICE_OPTIONS&quot;,   &quot;enabled&quot;, FALSE,
                &quot;CHECK_BOX_COMMANDS&quot;,         &quot;enabled&quot;, FALSE,
                &quot;COMBO_BOX_CONNECTION&quot;,       &quot;enabled&quot;, FALSE,
                &quot;COMBO_BOX_SUBSCRIPTION&quot;,     &quot;enabled&quot;, FALSE,
                &quot;COMBO_BOX_OLD_CONNECTION&quot;,   &quot;enabled&quot;, FALSE,
                &quot;COMBO_BOX_OLD_SUBSCRIPTION&quot;, &quot;enabled&quot;, FALSE,
                &quot;SPIN_BUTTON_DRIVER&quot;,         &quot;enabled&quot;, FALSE,
                &quot;PRIMITIVE_TEXT_SEARCHING&quot;,   &quot;visible&quot;, TRUE);



  // Detect all WCCOA opcua and sim
  if( DetectOpcUaDriverNumberManagers(diDriverNumbers, exceptionInfo) == FALSE )
  {
    disableAllShapes();
    exceptionInfo[2] = &quot;Error getting all manager driver numbers from the project, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }


  // Get driver number used for the new OPC UA connection
  sNewOpcUaServerConnection = COMBO_BOX_CONNECTION.text();
  if( GetOpcUaDriverNumber_FromOpcUaServerConnection(sNewOpcUaServerConnection, iNewOpcUaConnectionDriverNumber, exceptionInfo) == FALSE )
  {
    disableAllShapes();
    exceptionInfo[2] = &quot;Error getting the OPC UA driver number for OPC UA server connection: &quot; + sNewOpcUaServerConnection + &quot;, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }
  else
  {
    dynAppend(diDriverNumbers, iNewOpcUaConnectionDriverNumber);
    dynUnique(diDriverNumbers);
  }


  // Propose user to start all the simulators
  if( dynlen(diDriverNumbers) &gt; 0 )
  {
    fwGeneral_dynStringToString(diDriverNumbers, sDriverNumbers, &quot;,&quot;);
    ChildPanelOnCentralModalReturn(&quot;fwGeneral/fwMessageInfo1.pnl&quot;,
                                   &quot;DRIVER_NUMBER_INFO&quot;,
                                   makeDynString(&quot;$1:Please connect the following simulator managers: &quot; + sDriverNumbers + &quot; before pressing OK button&quot;),
                                   dfResult,
                                   dsResult);
  }


  while ( bDriversEnabled == FALSE )
  {
    // Check simulators are connected
    if( CheckSimulatorsStarted(diDriverNumbers, exceptionInfo) == FALSE )
    {
      exceptionInfo[2] = &quot;Error in required manager: &quot; + exceptionInfo[2];
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Please reconnected the required simulator or OPC UA client.  Remaining tries: &quot; + iNumberTries, &quot;&quot;);
      fwExceptionHandling_display(exceptionInfo);

    }
    else
    {
      bDriversEnabled = TRUE;
    }
    iNumberTries --;

    if( (iNumberTries &lt;= 0) &amp;&amp; (bDriversEnabled == FALSE) )
    {
      disableAllShapes();
      exceptionInfo[2] = &quot;Too many tries to reconnect required OPC UA clients or simulators, operation aborted&quot;;
      fwExceptionHandling_display(exceptionInfo);
      return;
    }
  }

  // Get the list of DPEs with their config: OPCUA server, OPCUA subscription, driver number
  sOpcUaConnectionFilter   = COMBO_BOX_OLD_CONNECTION.selectedText();
  sOpcUaSubscriptionFilter = COMBO_BOX_OLD_SUBSCRIPTION.selectedText();
  if( GetListOfDpesWithAddressing(sDeviceDp, bAddChildren, bIncludeCommands, sOpcUaConnectionFilter, sOpcUaSubscriptionFilter, dsDeviceDpes, ddaSettings, exceptionInfo) == FALSE )
  {
    disableAllShapes();
    exceptionInfo[2] = &quot;Error getting DPE address settings for all the devices to move, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }


  // Update global variables
  g_dsDeviceDpes = dsDeviceDpes;
  g_ddaSettings  = ddaSettings;

  if( dynlen(g_dsDeviceDpes) &gt; 0 )
  {
    // Display current settings and new ones
    if( PopulateDevicesInTable(g_dsDeviceDpes, g_ddaSettings, exceptionInfo) == FALSE )
    {
      disableAllShapes();
      exceptionInfo[2] = &quot;Error populating table to display DPEs changes, due to: &quot; + exceptionInfo[2];
      fwExceptionHandling_display(exceptionInfo);
      return;
    }

    setMultiValue(&quot;PUSH_BUTTON_SEARCH&quot;,       &quot;enabled&quot;, FALSE,
                  &quot;PUSH_BUTTON_PROCESS&quot;,      &quot;enabled&quot;, TRUE,
                  &quot;PRIMITIVE_TEXT_SEARCHING&quot;, &quot;visible&quot;, FALSE);
  }
  else
  {
    disableAllShapes();
    fwException_raise(exceptionInfo, &quot;INFO&quot;, &quot;There is no DPE matching your criteria: OPC UA address, OPC UA connections and OPC UA subscription.&quot;, &quot;&quot;);
    fwExceptionHandling_display(exceptionInfo);
    return;
  }

}




bool CheckSimulatorsStarted(dyn_int diDrivers, dyn_string &amp;exceptionInfo)
{
  int iLoop, iLen;
  dyn_int diDriverConnections;
  dyn_string dsDpes;
  dyn_dyn_anytype ddaValues;
  dyn_errClass deError;


  iLen = dynlen(diDrivers);


  // Get all driver connections
  dynAppend(dsDpes, &quot;_Connections.Driver.ManNums&quot;);

  // Get all internal DPs exists for the drivers
  for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
  {
    if( dpExists(&quot;_Driver&quot; + diDrivers[iLoop] + &quot;.DT&quot;) )
    {
      dynAppend(dsDpes, &quot;_Driver&quot; + diDrivers[iLoop] + &quot;.DT&quot;);
    }
    else
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, internal DP doesn't exist: _Driver&quot;  + diDrivers[iLoop], &quot;&quot;);
      return FALSE;
    }
  }

  // Get all values in one touch
  if( dpGet(dsDpes, ddaValues) != 0 )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error getting the driver managers connected&quot;, &quot;&quot;);
    return FALSE;
  }
  else
  {
    deError = getLastError();
    if( dynlen(deError) &gt; 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error getting the driver managers connected, due to: &quot; + getErrorText(deError), &quot;&quot;);
      return FALSE;
    }
  }

  // Extract the managers started
  diDriverConnections = ddaValues[1];
  dynRemove(ddaValues, 1);

  for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
  {
    // Check manager is started
    if( dynContains(diDriverConnections, diDrivers[iLoop]) &lt; 1 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;OPCUA client or Simulator manager &quot; + diDrivers[iLoop] + &quot;, is not running&quot;, &quot;&quot;);
      return FALSE;
    }


    // Check manager is a simulator or OPCUA driver
    if( (ddaValues[iLoop][1] != &quot;SIM&quot;)  &amp;&amp;
        (ddaValues[iLoop][1] != &quot;OPCUAC&quot;)  )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Manager &quot; + diDrivers[iLoop] + &quot;, is not a Simulator or OPC UA client&quot;, &quot;&quot;);
      return FALSE;
    }

  }

  return TRUE;
}




bool PopulateDevicesInTable(dyn_string dsDeviceDpes, dyn_dyn_anytype ddaSettings, dyn_string &amp;exceptionInfo)
{
  int iLenDpes, iLenSettings, iLoop, iPosX;
  dyn_int diDrivers;
  dyn_string dsConnections, dsSubscriptions;


  // Expand the panel
  setPanelSize(myModuleName(), myPanelName(), FALSE, (g_diPanelSize[1] * 2), g_diPanelSize[2]);

  // Move close button
  iPosX = g_iPosX *2 + 100;
  setValue(&quot;PUSH_BUTTON_CLOSE&quot;, &quot;position&quot;, iPosX, g_iPosY);


  // Check lenght dpes and properties are the same
  iLenDpes     = dynlen(dsDeviceDpes);
  iLenSettings = dynlen(ddaSettings);

  if( iLenDpes != iLenSettings )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error number of DPEs (&quot; + iLenDpes + &quot;) is different of number of settings (&quot; + iLenSettings + &quot;)&quot;, &quot;&quot;);
    return FALSE;
  }


  // Create arrays to populate faster the table
  for( iLoop = 1 ; iLoop &lt;= iLenSettings ; iLoop++ )
  {
    dynAppend(dsConnections,   ddaSettings[iLoop][12]);
    dynAppend(dsSubscriptions, ddaSettings[iLoop][13]);
    dynAppend(diDrivers,       ddaSettings[iLoop][2]);
  }


  TABLE_SETTINGS.appendLines(iLenDpes, &quot;DPE&quot;,                dsDeviceDpes,
                                       &quot;OPCUA_CONNECTION&quot;,   dsConnections,
                                       &quot;OPCUA_SUBSCRIPTION&quot;, dsSubscriptions,
                                       &quot;DRIVER&quot;,             diDrivers);


  return TRUE;
}




bool GetListOfDpesWithAddressing(string sDeviceDp, bool bIncludeChildren, bool bIncludeCommands, string sFilterServer, string sFilterSubscription, dyn_string &amp;dsDeviceDpes, dyn_dyn_anytype &amp;ddaSettings, dyn_string &amp;exceptionInfo)
{
  int iRes, iLen, iLoop;
  dyn_bool dbConfigExists, dbIsActive;
  dyn_string dsDpes, dsTempDpes, dsAddressExists;
  dyn_errClass deError;


  // Get all DPEs of the device/s
  dsDpes = dpNames(sDeviceDp + &quot;.**:_distrib.._type&quot;);

  if( bIncludeChildren )
  {
    dsTempDpes = dpNames(sDeviceDp + &quot;/**.**:_distrib.._type&quot;);
    dynAppend(dsDpes, dsTempDpes);
  }


  // Filter
  iLen = dynlen(dsDpes);
  if( iLen &gt; 0 )
  {
    iRes = dpGet(dsDpes, dsAddressExists);
    if( iRes != 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error filtering &quot; + dsDpes + &quot; DPEs without OPC DA addressing, due to non-existant DPEs: &quot; + dsDpes, &quot;&quot;);
      return FALSE;
    }
    deError = getLastError();
    if( dynlen(deError) &gt; 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error getting dpes with configured addresses, due to: &quot; + getErrorText(deError), &quot;&quot;);
      return FALSE;
    }


    for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
    {
      if( dsAddressExists[iLoop] != DPCONFIG_NONE )
      {
        dynAppend(dsDeviceDpes, dpSubStr(dsDpes[iLoop], DPSUB_DP_EL));
      }
    }
  }
  else
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, none address detected in your device, please start the properly simulator, and restart the panel, please&quot;, &quot;&quot;);
    return FALSE;
  }


  fwPeriphAddress_getMany(dsDeviceDpes, dbConfigExists, ddaSettings, dbIsActive, exceptionInfo);
  if( dynlen(exceptionInfo) &gt; 0 )
  {
    exceptionInfo[2] = &quot;Error getting address details, due to: &quot; + exceptionInfo[2];
    return FALSE;
  }


  // Remove entries where the config doesn't exist or the address type != OPCUA
  iLen = dynlen(dsDeviceDpes);
  for( iLoop = iLen ; iLoop &gt; 0 ; iLoop-- )
  {
    if( (dbConfigExists[iLoop] == FALSE) || (ddaSettings[iLoop][1] != &quot;OPCUA&quot;) )
    {
      dynRemove(dsDeviceDpes,   iLoop);
      dynRemove(dbConfigExists, iLoop);
      dynRemove(ddaSettings,    iLoop);
    }
  }

  // Remove entries that doesn't fit the OPC UA connection and subscription filters
  if( sFilterServer != &quot;Any&quot; )
  {
    iLen = dynlen(dsDeviceDpes);
    for( iLoop = iLen ; iLoop &gt; 0 ; iLoop-- )
    {
      if( (&quot;_&quot; + ddaSettings[iLoop][fwPeriphAddress_OPCUA_SERVER_NAME]) != sFilterServer )
      {
        dynRemove(dsDeviceDpes,   iLoop);
        dynRemove(dbConfigExists, iLoop);
        dynRemove(ddaSettings,    iLoop);
      }
    }
  }


  if( sFilterSubscription != &quot;Any&quot; )
  {
    // Check if include commands without subscriptions
    iLen = dynlen(dsDeviceDpes);
    for( iLoop = iLen ; iLoop &gt; 0 ; iLoop-- )
    {
      if( bIncludeCommands )
      {
        if( ((ddaSettings[iLoop][fwPeriphAddress_DIRECTION] == DPATTR_ADDR_MODE_OUTPUT)   ||
             (ddaSettings[iLoop][fwPeriphAddress_DIRECTION] == DPATTR_ADDR_MODE_IO_POLL)  ||
             (ddaSettings[iLoop][fwPeriphAddress_DIRECTION] == DPATTR_ADDR_MODE_IO_SQUERY)  ) &amp;&amp;
            (ddaSettings[iLoop][fwPeriphAddress_OPCUA_SUBSCRIPTION] == &quot;&quot; )                     )
        {
          continue;
        }

      }
      else
      {
        if( (&quot;_&quot; + ddaSettings[iLoop][fwPeriphAddress_OPCUA_SUBSCRIPTION]) != sFilterSubscription )
        {
          dynRemove(dsDeviceDpes,   iLoop);
          dynRemove(dbConfigExists, iLoop);
          dynRemove(ddaSettings,    iLoop);
        }
      }
    }
  }

  return TRUE;
}




bool DetectOpcUaDriverNumberManagers(dyn_int &amp;diDriverNumbers, dyn_string &amp;exceptionInfo)
{
  int iLoop, iLen, iPos, iDriverNumber;
  string sOption;
  dyn_string dsOptions;
  dyn_dyn_mixed ddmManagers;


  dynClear(diDriverNumbers);


  if( fwInstallationManager_getAllInfoFromPvss(ddmManagers) != 0 )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error getting all managers settings from the project&quot;, &quot;&quot;);
    return FALSE;
  }


  iLen = dynlen(ddmManagers);
  for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
  {
    // Check simulators and OPC UA client
    if( (ddmManagers[iLoop][1] == &quot;WCCILsim&quot;) || (ddmManagers[iLoop][1] == &quot;WCCOAopcua&quot;) )
    {
      // Get driver number
      dsOptions = strsplit(ddmManagers[iLoop][6], &quot;-&quot;);
      sOption   = dynPatternMatch(&quot;num *&quot;, dsOptions);
      if( sOption != &quot;&quot; )
      {
        strreplace(sOption, &quot;num &quot;, &quot;&quot;);
        iDriverNumber = (int)sOption;
        dynAppend(diDriverNumbers, iDriverNumber);
      }
    }
  }

  dynUnique(diDriverNumbers);

  return TRUE;
}



