                &quot;PUSH_BUTTON_CLOSE&quot;,          &quot;position&quot;,       g_iPosX, g_iPosY);

  initialize_OpcUaConnections();
  initialize_OpcUaSubscriptions();

  setPanelSize(myModuleName(), myPanelName(), FALSE, g_diPanelSize[1], g_diPanelSize[2]);
}
]]></script>
