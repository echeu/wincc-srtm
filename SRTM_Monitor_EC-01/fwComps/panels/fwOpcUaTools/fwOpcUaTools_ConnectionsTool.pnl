bool GetOpcUaDriverNumber_FromOpcUaServerConnection(string sOpcUaServerConnection, int &amp;iDriverNumber, dyn_string exceptionInfo)
{
  int iLen, iLoop;
  string sServerConnection, sDriver;
  dyn_string dsOpcUaDrivers;
  dyn_errClass deError;
  dyn_dyn_string ddsServerConnections;


  if( sOpcUaServerConnection == &quot;&quot; )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, new OPC UA Connection server name, can not be empty&quot;, &quot;&quot;);
    return FALSE;
  }
  else
  {
    dsOpcUaDrivers = dpNames(&quot;*.Config.Servers&quot;, &quot;_OPCUA&quot;);
    deError        = getLastError();
    if( dynlen(deError) &gt; 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error getting the list of OPC UA driver connections, due to: &quot; + getErrorText(), &quot;&quot;);
      return FALSE;
    }

    if( dynlen(dsOpcUaDrivers) &gt; 0 )
    {
      if( dpGet(dsOpcUaDrivers, ddsServerConnections) != 0 )
      {
        fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error getting OPC UA server connections&quot;, &quot;&quot;);
        return FALSE;
      }

      deError = getLastError();
      if( dynlen(deError) &gt; 0 )
      {
        fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error getting OPC UA server connections, due to: &quot; + getErrorText(deError), &quot;&quot;);
        return FALSE;
      }


      // Removing internal DP character: &quot;_&quot;
      sServerConnection = sOpcUaServerConnection;
      if( strpos(sServerConnection, &quot;_&quot;) == 0 )
      {
        sServerConnection = substr(sOpcUaServerConnection, 1);
      }

      iLen = dynlen(dsOpcUaDrivers);
      for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
      {
        if( dynContains(ddsServerConnections[iLoop], sServerConnection) &gt; 0 )
        {
          sDriver = dpSubStr(dsOpcUaDrivers[iLoop], DPSUB_DP);
          strreplace(sDriver, &quot;_OPCUA&quot;, &quot;&quot;);
          iDriverNumber = sDriver;
          return TRUE;
        }
      }
    }
  }

  return TRUE;
}




void Refresh_OpcUaConnections()
{
  bool bConnectionEnabled, bSubscriptionEnabled, bDriverEnabled, bMoveEnabled;
  int iLen, iDriverNumber;
  dyn_string dsConnections, dsSubscriptions, exceptionInfo;


  bConnectionEnabled   = FALSE;
  bSubscriptionEnabled = FALSE;
  bDriverEnabled       = FALSE;
  bMoveEnabled         = FALSE;
  setMultiValue(&quot;COMBO_BOX_CONNECTION&quot;,   &quot;deleteAllItems&quot;,
                &quot;COMBO_BOX_SUBSCRIPTION&quot;, &quot;deleteAllItems&quot;,
                &quot;SPIN_BUTTON_DRIVER&quot;,     &quot;value&quot;,          0,
                &quot;SPIN_BUTTON_DRIVER&quot;,     &quot;enabled&quot;,        FALSE);


  if( FindOpcUaConnections(dsConnections, exceptionInfo) == FALSE )
  {
    disableAllShapes();
    fwExceptionHandling_display(exceptionInfo);
    return;
  }


  iLen = dynlen(dsConnections);
  if( iLen &gt; 0 )
  {
    bConnectionEnabled = TRUE;
    if( FindOpcUaDriver(dsConnections[1], iDriverNumber, exceptionInfo) == FALSE )
    {
      disableAllShapes();
      fwExceptionHandling_display(exceptionInfo);
      return;
    }


    if( FindOpcUaSubscriptions(dsConnections[1], dsSubscriptions, exceptionInfo) == FALSE )
    {
      disableAllShapes();
      fwExceptionHandling_display(exceptionInfo);
      return;
    }

    setMultiValue(&quot;PUSH_BUTTON_COPY&quot;,     &quot;enabled&quot;,     TRUE,
                  &quot;COMBO_BOX_CONNECTION&quot;, &quot;items&quot;,       dsConnections,
                  &quot;COMBO_BOX_CONNECTION&quot;, &quot;selectedPos&quot;, 1,
                  &quot;SPIN_BUTTON_DRIVER&quot;,   &quot;value&quot;,       iDriverNumber);
    bConnectionEnabled = TRUE;
    bDriverEnabled     = TRUE;

    if( dynlen(dsSubscriptions) &gt; 0 )
    {
      dynAppend(dsSubscriptions, &quot;&quot;);
      setMultiValue(&quot;COMBO_BOX_SUBSCRIPTION&quot;, &quot;items&quot;,       dsSubscriptions,
                    &quot;COMBO_BOX_SUBSCRIPTION&quot;, &quot;selectedPos&quot;, 1);
      bSubscriptionEnabled = TRUE;
    }
  }
  else
  {
    PUSH_BUTTON_COPY.enabled(FALSE);
  }


  if( (bConnectionEnabled   == TRUE) &amp;&amp;
      (bSubscriptionEnabled == TRUE) &amp;&amp;
      (bDriverEnabled       == TRUE)   )
  {
    bMoveEnabled = TRUE;
  }

  setMultiValue(&quot;COMBO_BOX_CONNECTION&quot;,   &quot;enabled&quot;, bConnectionEnabled,
                &quot;COMBO_BOX_SUBSCRIPTION&quot;, &quot;enabled&quot;, bSubscriptionEnabled,
                &quot;PUSH_BUTTON_SEARCH&quot;,     &quot;enabled&quot;, bMoveEnabled);

}





void disableAllShapes()
{
  setMultiValue(//&quot;PUSH_BUTTON_JCOP&quot;,       &quot;enabled&quot;, FALSE,
                &quot;PUSH_BUTTON_NON_JCOP&quot;,       &quot;enabled&quot;, FALSE,
                &quot;PUSH_BUTTON_SEARCH&quot;,         &quot;enabled&quot;, FALSE,
                &quot;TEXT_FIELD_DP&quot;,              &quot;enabled&quot;, FALSE,
                &quot;COMBO_BOX_CONNECTION&quot;,       &quot;enabled&quot;, FALSE,
                &quot;COMBO_BOX_SUBSCRIPTION&quot;,     &quot;enabled&quot;, FALSE,
                &quot;COMBO_BOX_OLD_CONNECTION&quot;,   &quot;enabled&quot;, FALSE,
                &quot;COMBO_BOX_OLD_SUBSCRIPTION&quot;, &quot;enabled&quot;, FALSE,
                &quot;PRIMITIVE_TEXT_SEARCHING&quot;,   &quot;visible&quot;, FALSE);

}





bool FindOpcUaConnections(dyn_string &amp;dsConnections, dyn_string &amp;exceptionInfo)
{
  int iLen, iLoop;
  dyn_errClass deError;

  dsConnections = dpNames(&quot;*&quot;, &quot;_OPCUAServer&quot;);
  deError       = getLastError();
  if( dynlen(deError) &gt; 0 )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;FindOpcUaConnections() -&gt; Error getting OPC UA server connections due to: &quot; + getErrorText(deError), &quot;&quot;);
    return FALSE;
  }
  else
  {
    iLen = dynlen(dsConnections);
    for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
    {
      dsConnections[iLoop] = dpSubStr(dsConnections[iLoop], DPSUB_DP);
    }
    return TRUE;
  }

}




bool FindOpcUaSubscriptions(string sConnection, dyn_string &amp;dsSubscriptions, dyn_string &amp;exceptionInfo)
{
  int iRes, iLen, iLoop;
  dyn_errClass deError;


  // Check OPC UA connection exists
  if( dpExists(sConnection) == FALSE )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;FindOpcUaSubscriptions() -&gt; Error OPC UA server connection does not exist: &quot; + sConnection, &quot;&quot;);
    return FALSE;
  }


  iRes = dpGet( sConnection + &quot;.Config.Subscriptions&quot;, dsSubscriptions);
  if( iRes != 0 )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;FindOpcUaSubscriptions() -&gt; Error getting subscriptions for connection: &quot; + sConnection, &quot;&quot;);
    return FALSE;
  }
  else
  {
    deError = getLastError();
    if( dynlen(deError) &gt; 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;FindOpcUaSubscriptions() -&gt; Error getting subscriptions for connection: &quot; + sConnection + &quot; due to: &quot; + getErrorText(deError), &quot;&quot;);
      return FALSE;
    }
  }

  iLen = dynlen(dsSubscriptions);
  for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
  {
    dsSubscriptions[iLoop] = dpSubStr(dsSubscriptions[iLoop], DPSUB_DP);
  }


  return TRUE;
}





bool FindOpcUaDriver(string sConnection, int &amp;iDriverNumber, dyn_string &amp;exceptionInfo)
{
  int iLoop, iLen, iRes, iPos;
  string sConnectionCut;
  dyn_int diDriverNumbers;
  dyn_string dsDrivers, dsDriversServers;
  dyn_errClass deError;


  // Check OPC UA connection exists
  if( dpExists(sConnection) == FALSE )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;FindOpcUaDriver() -&gt; Error OPC UA server connection does not exist: &quot; + sConnection, &quot;&quot;);
    return FALSE;
  }

  sConnectionCut = substr(dpSubStr(sConnection, DPSUB_DP), 1);
  dsDrivers      = dpNames(&quot;*.Config.Servers&quot;, &quot;_OPCUA&quot;);
  deError        = getLastError();
  if( dynlen(deError) &gt; 0 )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;FindOpcUaDriver() -&gt; Error getting OPC UA driver DPs, due to: &quot; + getErrorText(deError), &quot;&quot;);
    return FALSE;
  }

  iLen = dynlen(dsDrivers);
  for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
  {
    iRes = dpGet(dsDrivers[iLoop], dsDriversServers);
    if( iRes != 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;FindOpcUaDriver() -&gt; Error getting connections from driver: &quot; + dsDrivers[iLoop], &quot;&quot;);
      return FALSE;
    }
    else
    {
      deError = getLastError();
      if( dynlen(deError) &gt; 0 )
      {
        fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;FindOpcUaDriver() -&gt; Error getting connections from driver: &quot; + dsDrivers[iLoop] + &quot; due to: &quot; + getErrorText(), &quot;&quot;);
        return FALSE;
      }
    }

    iPos = dynContains( dsDriversServers, sConnectionCut );
    if( iPos &gt; 0 )
    {
      dsDrivers[iLoop] = dpSubStr(dsDrivers[iLoop], DPSUB_DP);
      sscanf(dsDrivers[iLoop], &quot;_OPCUA%d&quot;, iDriverNumber);
      dynAppend(diDriverNumbers, iDriverNumber);
    }
  }

  if( dynlen(diDriverNumbers) &gt; 1 )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;FindOpcUaDriver() -&gt; Error, OPC UA connection: &quot; + sConnection + &quot; is registered in more than one driver: &quot; + diDriverNumbers, &quot;&quot;);
    return FALSE;
  }

  return TRUE;
}





void initialize_OpcUaConnections()
{
  int iLen, iLoop;
  dyn_string dsAllServers, dsServers;

  dsAllServers = dpNames(getSystemName() + &quot;*&quot;, &quot;_OPCUAServer&quot;);
  iLen         = dynlen(dsAllServers);
  dynAppend(dsServers, &quot;Any&quot;);

  if( iLen &gt; 0 )
  {
    // Remove redundant connections
    for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
    {
      // Redundant connection = CONNECTION + _2
      if( strpos(dsAllServers[iLoop], &quot;_2&quot;) != (strlen(dsAllServers[iLoop])-2) )
      {
        dynAppend(dsServers, dpSubStr(dsAllServers[iLoop], DPSUB_DP));
      }
    }
  }

  COMBO_BOX_OLD_CONNECTION.deleteAllItems();
  COMBO_BOX_OLD_CONNECTION.items(dsServers);
  COMBO_BOX_OLD_CONNECTION.selectedPos(1);
}




void initialize_OpcUaSubscriptions()
{
  int iLen, iLoop;
  dyn_string dsAllSubscriptions, dsSubscriptions;


  dsAllSubscriptions = dpNames(getSystemName() + &quot;*&quot;, &quot;_OPCUASubscription&quot;);
  iLen               = dynlen(dsAllSubscriptions);
  dynAppend(dsSubscriptions, &quot;Any&quot;);


  if( iLen &gt; 0 )
  {
    // Remove redundant subscriptions
    for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
    {
      // Redundant subscription = SUBSCRIPTION + _2
      if( strpos(dsAllSubscriptions[iLoop], &quot;_2&quot;) != (strlen(dsAllSubscriptions[iLoop])-2) )
      {
        dynAppend(dsSubscriptions, dpSubStr(dsAllSubscriptions[iLoop], DPSUB_DP));
      }
    }
  }

  COMBO_BOX_OLD_SUBSCRIPTION.deleteAllItems();
  COMBO_BOX_OLD_SUBSCRIPTION.items(dsSubscriptions);
  COMBO_BOX_OLD_SUBSCRIPTION.selectedPos(1);

}





]]></script>
  <script name="Initialize" isEscaped="1"><![CDATA[main()
{
  g_diPanelSize = getPanelSize(myPanelName());
  getValue(&quot;PUSH_BUTTON_CLOSE&quot;, &quot;position&quot;, g_iPosX, g_iPosY);

  initialize_OpcUaConnections();

  initialize_OpcUaSubscriptions();

}




