  <shape Name="COMBO_BOX_CONNECTION" shapeType="COMBO_BOX" layerId="0">
   <properties>
    <prop name="serialId">9</prop>
    <prop name="Type"></prop>
    <prop name="RefPoint">-363.8461538461538 299.75</prop>
    <prop name="Enable">False</prop>
    <prop name="Visible">True</prop>
    <prop name="ForeColor">_WindowText</prop>
    <prop name="BackColor">_Window</prop>
    <prop name="TabOrder">9</prop>
    <prop name="ToolTipText">
     <prop name="en_US.utf8"></prop>
    </prop>
    <prop name="layoutAlignment">AlignNone</prop>
    <prop name="snapMode">Point</prop>
    <prop name="Font">
     <prop name="en_US.utf8">MS Shell Dlg 2,-1,11,5,50,0,0,0,0,0</prop>
    </prop>
    <prop name="Location">110 431.75</prop>
    <prop name="Size">421 20</prop>
    <prop name="Listitems"/>
    <prop name="Editable">False</prop>
   </properties>
   <events>
    <script name="Changed" isEscaped="1"><![CDATA[main()
{
  int iLen, iLoop, iPos;
  string sConnection, sConnectionCut, sDriver;
  dyn_string dsSubscriptions, dsDrivers, dsDriversServers, exceptionInfo;
  dyn_errClass deError;


  getValue(&quot;COMBO_BOX_CONNECTION&quot;, &quot;selectedText&quot;, sConnection);
  setValue(&quot;COMBO_BOX_SUBSCRIPTION&quot;, &quot;deleteAllItems&quot;);
  sConnectionCut = substr(dpSubStr(sConnection, DPSUB_DP), 1);

  if( dpGet(sConnection + &quot;.Config.Subscriptions&quot;, dsSubscriptions) != 0 )
  {
    disableAllShapes();
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error getting subscriptions from OPC UA connection: &quot; + sConnectionCut, &quot;&quot;);
    fwExceptionHandling_display(exceptionInfo);
    return;
  }
  else
  {
    deError = getLastError();
    if( dynlen(deError) &gt; 0 )
    {
      disableAllShapes();
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error getting subscriptions from OPC UA connection: &quot; + sConnectionCut + &quot;, due to: &quot; + getErrorText(deError), &quot;&quot;);
      fwExceptionHandling_display(exceptionInfo);
      return;
    }
  }

  iLen = dynlen(dsSubscriptions);
  for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
  {
    dsSubscriptions[iLoop] = dpSubStr(dsSubscriptions[iLoop], DPSUB_DP);
  }



  if( dynlen(dsSubscriptions) &gt; 0 )
  {
    dynAppend(dsSubscriptions, &quot;&quot;);
    setMultiValue(&quot;COMBO_BOX_SUBSCRIPTION&quot;, &quot;items&quot;,       dsSubscriptions,
                  &quot;COMBO_BOX_SUBSCRIPTION&quot;, &quot;enabled&quot;,     TRUE,
                  &quot;COMBO_BOX_SUBSCRIPTION&quot;, &quot;selectedPos&quot;, 1);
  }


  dsDrivers = dpNames(&quot;*.Config.Servers&quot;, &quot;_OPCUA&quot;);
  iLen = dynlen(dsDrivers);
  if( iLen &gt; 0 )
  {
    for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
    {
      if( dpGet(dsDrivers[iLoop], dsDriversServers) != 0 )
      {
        disableAllShapes();
        fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error getting OPC UA servers from the driver: &quot; + dsDrivers[iLoop], &quot;&quot;);
        fwExceptionHandling_display(exceptionInfo);
        return;
      }
      else
      {
        deError = getLastError();
        if( dynlen(deError) &gt; 0 )
        {
          disableAllShapes();
          fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error getting OPC UA servers from the driver: &quot; + dsDrivers[iLoop] + &quot;, due to: &quot; + getErrorText(deError), &quot;&quot;);
          fwExceptionHandling_display(exceptionInfo);
          return;
        }
      }

      iPos = dynContains( dsDriversServers, sConnectionCut );
      if( iPos &gt; 0 )
      {
        sDriver = dpSubStr(dsDrivers[iLoop], DPSUB_DP);
        strreplace(sDriver, &quot;_OPCUA&quot;, &quot;&quot;);
        setValue(&quot;SPIN_BUTTON_DRIVER&quot;, &quot;value&quot;, sDriver);
      }
    }
  }
}




]]></script>
   </events>
