  <shape Name="PUSH_BUTTON_PROCESS" shapeType="PUSH_BUTTON" layerId="0">
   <properties>
    <prop name="serialId">34</prop>
    <prop name="Type"></prop>
    <prop name="RefPoint">1000 545</prop>
    <prop name="Enable">False</prop>
    <prop name="Visible">True</prop>
    <prop name="ForeColor">_ButtonText</prop>
    <prop name="BackColor">_Button</prop>
    <prop name="TabOrder">32</prop>
    <prop name="ToolTipText">
     <prop name="en_US.utf8"></prop>
    </prop>
    <prop name="layoutAlignment">AlignNone</prop>
    <prop name="snapMode">Point</prop>
    <prop name="Font">
     <prop name="en_US.utf8">MS Shell Dlg 2,-1,10,5,50,0,0,0,0,0</prop>
    </prop>
    <prop name="Location">1000 539</prop>
    <prop name="Size">121 23</prop>
    <prop name="BorderStyle">Styled</prop>
    <prop name="Text">
     <prop name="en_US.utf8">Process changes</prop>
    </prop>
   </properties>
   <events>
    <script name="Clicked" isEscaped="1"><![CDATA[main(mapping event)
{
  int iLenDpes, iLenSettings, iLoop, iNewDriver;
  string sNewConnection, sNewSubscription;
  dyn_string exceptionInfo;
  dyn_dyn_anytype ddaNewSettings;


  setMultiValue(&quot;PUSH_BUTTON_PROCESS&quot;,    &quot;enabled&quot;, FALSE,
                &quot;PRIMITIVE_TEXT_PROCESS&quot;, &quot;visible&quot;, TRUE);

  // Check Device DPEs and SETTINGS lenght
  iLenDpes     = dynlen(g_dsDeviceDpes);
  iLenSettings = dynlen(g_ddaSettings);

  if( iLenDpes != iLenSettings )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error the number of DPEs is different from the number of settings&quot;, &quot;&quot;);
    fwExceptionHandling_display(exceptionInfo);
    return;
  }

  // Change the OPC UA driver, OPC UA server connection and OPC UA subscription
  ddaNewSettings   = g_ddaSettings;
  iNewDriver       = SPIN_BUTTON_DRIVER.value();
  sNewConnection   = RemoveOpcUaInternalCharacter(COMBO_BOX_CONNECTION.selectedText());
  sNewSubscription = RemoveOpcUaInternalCharacter(COMBO_BOX_SUBSCRIPTION.selectedText());


  for( iLoop = 1 ; iLoop &lt;= iLenSettings ; iLoop++ )
  {
    ddaNewSettings[iLoop][2]  = iNewDriver;
    ddaNewSettings[iLoop][12] = sNewConnection;
    if( sNewSubscription != &quot;&quot; )
    {
      ddaNewSettings[iLoop][13] = sNewSubscription;
    }
  }

  // Apply changes to DPEs
  fwPeriphAddress_setMany(g_dsDeviceDpes, ddaNewSettings, exceptionInfo);
  setValue(&quot;PRIMITIVE_TEXT_PROCESS&quot;, &quot;visible&quot;, FALSE);
  if( dynlen(exceptionInfo) &gt; 0 )
  {
    exceptionInfo[2] = &quot;Error, updating the Device DPEs with new addressing, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }


  ChildPanelOnCentralModal(&quot;fwGeneral/fwMessageInfo1.pnl&quot;,
                           &quot;PROCESS_DONE&quot;,
                           makeDynString(&quot;$1:Process done. All the DPEs has been updated without errors. You can start now the properly OPC UA clients&quot;));

}





string RemoveOpcUaInternalCharacter(string sInternalOpcDp)
{
  sInternalOpcDp = dpSubStr(sInternalOpcDp, DPSUB_DP);

  if( strpos(sInternalOpcDp, &quot;_&quot;) == 0 )
  {
    return (substr(sInternalOpcDp, 1));
  }
  else
    return sInternalOpcDp;
}


]]></script>
