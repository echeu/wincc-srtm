    <script name="Clicked" isEscaped="1"><![CDATA[main(mapping event)
{
  string sNonJcopDevice;


  setValue(&quot;CHECK_BOX_JCOP_DEVICE&quot;, &quot;state&quot;, 0, FALSE);

  if( dpSelector(sNonJcopDevice, FALSE, &quot;OWN_SYSTEM_NAME_SYS&quot;, FALSE ) != 0 )
  {
    setValue(&quot;TEXT_FIELD_DP&quot;, &quot;text&quot;, &quot;&quot;);
    return;
  }

  if( sNonJcopDevice != &quot;&quot; )
  {
    setValue(&quot;TEXT_FIELD_DP&quot;, &quot;text&quot;, sNonJcopDevice);
    Refresh_OpcUaConnections();
  }
  else
  {
    setValue(&quot;TEXT_FIELD_DP&quot;, &quot;text&quot;, &quot;&quot;);
    return;
  }

}


