  <shape Name="PUSH_BUTTON_COPY" shapeType="PUSH_BUTTON" layerId="0">
   <properties>
    <prop name="serialId">53</prop>
    <prop name="Type"></prop>
    <prop name="RefPoint">110 500</prop>
    <prop name="Enable">False</prop>
    <prop name="Visible">True</prop>
    <prop name="ForeColor">_ButtonText</prop>
    <prop name="BackColor">_Button</prop>
    <prop name="TabOrder">49</prop>
    <prop name="ToolTipText">
     <prop name="en_US.utf8"></prop>
    </prop>
    <prop name="layoutAlignment">AlignNone</prop>
    <prop name="snapMode">Point</prop>
    <prop name="Font">
     <prop name="en_US.utf8">MS Shell Dlg 2,-1,11,5,50,0,0,0,0,0</prop>
    </prop>
    <prop name="Location">110 495</prop>
    <prop name="Size">251 23</prop>
    <prop name="BorderStyle">Styled</prop>
    <prop name="Text">
     <prop name="en_US.utf8">Create new connection based on existant</prop>
    </prop>
   </properties>
   <events>
    <script name="Clicked" isEscaped="1"><![CDATA[main(mapping event)
{
  int iDriverNumber;
  string sNewOpcUaServer, sCopyFromServer, sNewOpcUaSubscription, sCopyFromSubscription;
  dyn_float dfResult;
  dyn_string dsResult, exceptionInfo;


  ChildPanelOnCentralModalReturn(&quot;fwOpcUaTools/fwOpcUaTools_ConnectionsTool_createConnection.pnl&quot;,
                                 &quot;Copy OPC UA connection settings&quot;,
                                 makeDynString(),
                                 dfResult,
                                 dsResult);

  if( ( dynlen(dfResult) &lt; 1 ) ||
      ( dfResult[1] == 0     )  )
  {
    return;
  }
  else
  {
    iDriverNumber         = dsResult[1];
    sNewOpcUaServer       = dsResult[2];
    sCopyFromServer       = dsResult[3];
    sNewOpcUaSubscription = dsResult[4];
    sCopyFromSubscription = dsResult[5];
  }


  // Create new OPC UA driver
  if( createDp(&quot;_OPCUA&quot; + iDriverNumber, &quot;_OPCUA&quot;, exceptionInfo) == FALSE )
  {
    disableAllShapes();
    exceptionInfo[2] = &quot;Error creating OPC UA driver connection DP, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }


  // Create internal DPs
  if( createDp(&quot;_Stat_Configs_driver_&quot; + iDriverNumber, &quot;_Statistics_DriverConfigs&quot;, exceptionInfo) == FALSE )
  {
    disableAllShapes();
    exceptionInfo[2] = &quot;Error creating internal Driver DP, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }

  if( createDp(&quot;_Stat_2_Configs_driver_&quot; + iDriverNumber, &quot;_Statistics_DriverConfigs&quot;, exceptionInfo) == FALSE )
  {
    disableAllShapes();
    exceptionInfo[2] = &quot;Error creating internal Driver DP, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }


  if( createDp(&quot;_Driver&quot; + iDriverNumber, &quot;_DriverCommon&quot;, exceptionInfo) == FALSE )
  {
    disableAllShapes();
    exceptionInfo[2] = &quot;Error creating internal Driver DP, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }

  if( createDp(&quot;_Driver&quot; + iDriverNumber + &quot;_2&quot;, &quot;_DriverCommon&quot;, exceptionInfo) == FALSE )
  {
    disableAllShapes();
    exceptionInfo[2] = &quot;Error creating internal Driver DP, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }



  // Create new OPC UA server connection
  if( createDp(sNewOpcUaServer, &quot;_OPCUAServer&quot;, exceptionInfo) == FALSE )
  {
    disableAllShapes();
    exceptionInfo[2] = &quot;Error creating OPC UA server connection DP, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }

  if( createDp(sNewOpcUaServer + &quot;_2&quot;, &quot;_OPCUAServer&quot;, exceptionInfo) == FALSE )
  {
    disableAllShapes();
    exceptionInfo[2] = &quot;Error creating OPC UA server connection DP, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }


  // Create new OPC UA server subscription
  if( sNewOpcUaSubscription != &quot;&quot; )
  {
    if( createDp(sNewOpcUaSubscription, &quot;_OPCUASubscription&quot;, exceptionInfo) == FALSE )
    {
      disableAllShapes();
      exceptionInfo[2] = &quot;Error creating OPC UA subscription DP, due to: &quot; + exceptionInfo[2];
      fwExceptionHandling_display(exceptionInfo);
      return;
    }

    if( createDp(sNewOpcUaSubscription + &quot;_2&quot;, &quot;_OPCUASubscription&quot;, exceptionInfo) == FALSE )
    {
      disableAllShapes();
      exceptionInfo[2] = &quot;Error creating OPC UA subscription DP, due to: &quot; + exceptionInfo[2];
      fwExceptionHandling_display(exceptionInfo);
      return;
    }
  }


  // Configure OPC UA driver, server and connection
  if( configureOpcUaDps(iDriverNumber,         &quot;_OPCUA&quot; + iDriverNumber,
                        sNewOpcUaServer,       sNewOpcUaServer + &quot;_2&quot;,       sCopyFromServer,
                        sNewOpcUaSubscription, sNewOpcUaSubscription + &quot;_2&quot;, sCopyFromSubscription,
                        exceptionInfo) == FALSE )
  {
    disableAllShapes();
    exceptionInfo[2] = &quot;Error configuring new OPC UA driver, server and subscriptions, due to: &quot; + exceptionInfo[2];
    fwExceptionHandling_display(exceptionInfo);
    return;
  }


  // Create simulator and OPC UA client managers
  if( CreateManagers(iDriverNumber, exceptionInfo) == FALSE )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error creating simulator and OPC UA client managers&quot;, &quot;&quot;);
    fwExceptionHandling_display(exceptionInfo);
    return;
  }


  // Update main panel
  Refresh_OpcUaConnections();

}





bool configureOpcUaDps(int iDriverNumber,         string sOpcUaDriver,
                       string sOpcUaServer,       string sOpcUaServerRedundant,       string sOpcUaServerSettings,
                       string sOpcUaSubscription, string sOpcUaSubscriptionRedundant, string sOpcUaSubscriptionSettings,
                       dyn_string &amp;exceptionInfo)
{
  string sOpcUaServerCut, sOpcUaSubscriptionCut, sDescription;
  dyn_string exceptionInfo;
  dyn_errClass deError;
  mapping mServer, mSubscription;


  // Remove &quot;_&quot; character from OPC UA server connection
  if( strpos(sOpcUaServer, &quot;_&quot;) == 0 )
  {
    sOpcUaServerCut = substr(sOpcUaServer, 1);
  }

  // Get source properties from OPC UA server connection and OPC UA subscription
  if( dpGet(sOpcUaServerSettings + &quot;.Config.ConnInfo&quot;,             mServer[&quot;ConnInfo&quot;],
            sOpcUaServerSettings + &quot;.Config.AccessInfo&quot;,           mServer[&quot;AccessInfo&quot;],
            sOpcUaServerSettings + &quot;.Config.Password&quot;,             mServer[&quot;Password&quot;],
            sOpcUaServerSettings + &quot;.Config.Security.Policy&quot;,      mServer[&quot;Policy&quot;],
            sOpcUaServerSettings + &quot;.Config.Security.MessageMode&quot;, mServer[&quot;MessageMode&quot;],
            sOpcUaServerSettings + &quot;.Config.Security.Certificate&quot;, mServer[&quot;Certificate&quot;],
            sOpcUaServerSettings + &quot;.Config.Active&quot;,               mServer[&quot;Active&quot;],
            sOpcUaServerSettings + &quot;.Config.ReconnectTimer&quot;,       mServer[&quot;ReconnectTimer&quot;],
            sOpcUaServerSettings + &quot;.Config.StatusMapping&quot;,        mServer[&quot;StatusMapping&quot;],
            sOpcUaServerSettings + &quot;.Config.Separator&quot;,            mServer[&quot;Separator&quot;],
            sOpcUaServerSettings + &quot;.Redu.Config.ConnInfo&quot;,        mServer[&quot;ReduConnInfo&quot;],
            sOpcUaServerSettings + &quot;.Redu.Config.Active&quot;,          mServer[&quot;ReduActive&quot;]) != 0 )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error reading config settings from: &quot; + sOpcUaServerSettings, &quot;&quot;);
    return FALSE;
  }
  else
  {
    deError = getLastError();
    if( dynlen(deError) &gt; 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error reading config settings from: &quot; + sOpcUaServerSettings + &quot;, due to: &quot; + getErrorText(), &quot;&quot;);
      return FALSE;
    }

    dpGetDescription(sOpcUaServerSettings + &quot;.&quot;, sDescription);
  }


  // Configure OPC UA server connections
  if( dpSet(sOpcUaServer          + &quot;.Config.ConnInfo&quot;,             mServer[&quot;ConnInfo&quot;],
            sOpcUaServerRedundant + &quot;.Config.ConnInfo&quot;,             mServer[&quot;ConnInfo&quot;],
            sOpcUaServer          + &quot;.Config.AccessInfo&quot;,           mServer[&quot;AccessInfo&quot;],
            sOpcUaServerRedundant + &quot;.Config.AccessInfo&quot;,           mServer[&quot;AccessInfo&quot;],
            sOpcUaServer          + &quot;.Config.Password&quot;,             mServer[&quot;Password&quot;],
            sOpcUaServerRedundant + &quot;.Config.Password&quot;,             mServer[&quot;Password&quot;],
            sOpcUaServer          + &quot;.Config.Security.Policy&quot;,      mServer[&quot;Policy&quot;],
            sOpcUaServerRedundant + &quot;.Config.Security.Policy&quot;,      mServer[&quot;Policy&quot;],
            sOpcUaServer          + &quot;.Config.Security.MessageMode&quot;, mServer[&quot;MessageMode&quot;],
            sOpcUaServerRedundant + &quot;.Config.Security.MessageMode&quot;, mServer[&quot;MessageMode&quot;],
            sOpcUaServer          + &quot;.Config.Security.Certificate&quot;, mServer[&quot;Certificate&quot;],
            sOpcUaServerRedundant + &quot;.Config.Security.Certificate&quot;, mServer[&quot;Certificate&quot;],
            sOpcUaServer          + &quot;.Config.Active&quot;,               mServer[&quot;Active&quot;],
            sOpcUaServerRedundant + &quot;.Config.Active&quot;,               mServer[&quot;Active&quot;],
            sOpcUaServer          + &quot;.Config.ReconnectTimer&quot;,       mServer[&quot;ReconnectTimer&quot;],
            sOpcUaServerRedundant + &quot;.Config.ReconnectTimer&quot;,       mServer[&quot;ReconnectTimer&quot;],
            sOpcUaServer          + &quot;.Config.StatusMapping&quot;,        mServer[&quot;StatusMapping&quot;],
            sOpcUaServerRedundant + &quot;.Config.StatusMapping&quot;,        mServer[&quot;StatusMapping&quot;],
            sOpcUaServer          + &quot;.Config.Separator&quot;,            mServer[&quot;Separator&quot;],
            sOpcUaServerRedundant + &quot;.Config.Separator&quot;,            mServer[&quot;Separator&quot;],
            sOpcUaServer          + &quot;.Redu.Config.ConnInfo&quot;,        mServer[&quot;ReduConnInfo&quot;],
            sOpcUaServerRedundant + &quot;.Redu.Config.ConnInfo&quot;,        mServer[&quot;ReduConnInfo&quot;],
            sOpcUaServer          + &quot;.Redu.Config.Active&quot;,          mServer[&quot;ReduActive&quot;],
            sOpcUaServerRedundant + &quot;.Redu.Config.Active&quot;,          mServer[&quot;ReduActive&quot;],
            sOpcUaDriver          + &quot;.Config.Servers&quot;,              makeDynString(sOpcUaServerCut)) != 0 )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error configuring OPC UA server config: &quot; + sOpcUaServer, &quot;&quot;);
    return FALSE;
  }
  else
  {
    deError = getLastError();
    if( dynlen(deError) &gt; 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error configuring OPC UA server config: &quot; + sOpcUaServer + &quot;, due to: &quot; + getErrorText(), &quot;&quot;);
      return FALSE;
    }

    // Copy OPC UA server connection description
    dpSetDescription(sOpcUaServer          + &quot;.&quot;, sDescription);
    dpSetDescription(sOpcUaServerRedundant + &quot;.&quot;, sDescription);
  }



  // If subscription name is empty, nothing needs to be configured
  if( (sOpcUaSubscription != &quot;&quot;) &amp;&amp; (sOpcUaSubscriptionRedundant != &quot;&quot;) )
  {
    if( dpGet(sOpcUaSubscriptionSettings + &quot;.Config.RequestedLifetimeCount&quot;,                        mSubscription[&quot;RequestedLifeTimeCount&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.RequestedMaxKeepAliveCount&quot;,                    mSubscription[&quot;RequestedMaxKeepAliveCount&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.MaxNotificationsPerPublish&quot;,                    mSubscription[&quot;MaxNotificationsPerPublish&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.PublishingEnabled&quot;,                             mSubscription[&quot;PublishingEnabled&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.Priority&quot;,                                      mSubscription[&quot;Priority&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.SubscriptionType&quot;,                              mSubscription[&quot;SubscriptionType&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.MonitoredItems.TimestampsToReturn&quot;,             mSubscription[&quot;TimeStampsToReturn&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.MonitoredItems.QueueSize&quot;,                      mSubscription[&quot;QueueSize&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.MonitoredItems.DiscardOldest&quot;,                  mSubscription[&quot;DiscardOldest&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.MonitoredItems.DataChangeFilter.Trigger&quot;,       mSubscription[&quot;Trigger&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.MonitoredItems.DataChangeFilter.DeadbandType&quot;,  mSubscription[&quot;DeadbandType&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.MonitoredItems.DataChangeFilter.DeadbandValue&quot;, mSubscription[&quot;DeadbandValue&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.MonitoredItems.SamplingInterval&quot;,               mSubscription[&quot;SamplingInterval&quot;],
              sOpcUaSubscriptionSettings + &quot;.Config.RequestedPublishingInterval&quot;,                   mSubscription[&quot;RequestedPublishingInterval&quot;]) != 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error reading subscription settings from: &quot; + sOpcUaSubscriptionSettings, &quot;&quot;);
      return FALSE;
    }
    else
    {
      deError = getLastError();
      if( dynlen(deError) &gt; 0 )
      {
        fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error reading subscription settings from: &quot; + sOpcUaSubscriptionSettings + &quot;, due to: &quot; + getErrorText(), &quot;&quot;);
        return FALSE;
      }

      dpGetDescription(sOpcUaSubscriptionSettings + &quot;.&quot;, sDescription);
    }


    // Apply subscription settings and register subscriptions
    if( dpSet(sOpcUaSubscription          + &quot;.Config.RequestedLifetimeCount&quot;,                        mSubscription[&quot;RequestedLifeTimeCount&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.RequestedLifetimeCount&quot;,                        mSubscription[&quot;RequestedLifeTimeCount&quot;],
              sOpcUaSubscription          + &quot;.Config.RequestedMaxKeepAliveCount&quot;,                    mSubscription[&quot;RequestedMaxKeepAliveCount&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.RequestedMaxKeepAliveCount&quot;,                    mSubscription[&quot;RequestedMaxKeepAliveCount&quot;],
              sOpcUaSubscription          + &quot;.Config.MaxNotificationsPerPublish&quot;,                    mSubscription[&quot;MaxNotificationsPerPublish&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.MaxNotificationsPerPublish&quot;,                    mSubscription[&quot;MaxNotificationsPerPublish&quot;],
              sOpcUaSubscription          + &quot;.Config.PublishingEnabled&quot;,                             mSubscription[&quot;PublishingEnabled&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.PublishingEnabled&quot;,                             mSubscription[&quot;PublishingEnabled&quot;],
              sOpcUaSubscription          + &quot;.Config.Priority&quot;,                                      mSubscription[&quot;Priority&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.Priority&quot;,                                      mSubscription[&quot;Priority&quot;],
              sOpcUaSubscription          + &quot;.Config.SubscriptionType&quot;,                              mSubscription[&quot;SubscriptionType&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.SubscriptionType&quot;,                              mSubscription[&quot;SubscriptionType&quot;],
              sOpcUaSubscription          + &quot;.Config.MonitoredItems.TimestampsToReturn&quot;,             mSubscription[&quot;TimeStampsToReturn&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.MonitoredItems.TimestampsToReturn&quot;,             mSubscription[&quot;TimeStampsToReturn&quot;],
              sOpcUaSubscription          + &quot;.Config.MonitoredItems.QueueSize&quot;,                      mSubscription[&quot;QueueSize&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.MonitoredItems.QueueSize&quot;,                      mSubscription[&quot;QueueSize&quot;],
              sOpcUaSubscription          + &quot;.Config.MonitoredItems.DiscardOldest&quot;,                  mSubscription[&quot;DiscardOldest&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.MonitoredItems.DiscardOldest&quot;,                  mSubscription[&quot;DiscardOldest&quot;],
              sOpcUaSubscription          + &quot;.Config.MonitoredItems.DataChangeFilter.Trigger&quot;,       mSubscription[&quot;Trigger&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.MonitoredItems.DataChangeFilter.Trigger&quot;,       mSubscription[&quot;Trigger&quot;],
              sOpcUaSubscription          + &quot;.Config.MonitoredItems.DataChangeFilter.DeadbandType&quot;,  mSubscription[&quot;DeadbandType&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.MonitoredItems.DataChangeFilter.DeadbandType&quot;,  mSubscription[&quot;DeadbandType&quot;],
              sOpcUaSubscription          + &quot;.Config.MonitoredItems.DataChangeFilter.DeadbandValue&quot;, mSubscription[&quot;DeadbandValue&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.MonitoredItems.DataChangeFilter.DeadbandValue&quot;, mSubscription[&quot;DeadbandValue&quot;],
              sOpcUaSubscription          + &quot;.Config.MonitoredItems.SamplingInterval&quot;,               mSubscription[&quot;SamplingInterval&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.MonitoredItems.SamplingInterval&quot;,               mSubscription[&quot;SamplingInterval&quot;],
              sOpcUaSubscription          + &quot;.Config.RequestedPublishingInterval&quot;,                   mSubscription[&quot;RequestedPublishingInterval&quot;],
              sOpcUaSubscriptionRedundant + &quot;.Config.RequestedPublishingInterval&quot;,                   mSubscription[&quot;RequestedPublishingInterval&quot;],
              sOpcUaServer                + &quot;.Config.Subscriptions&quot;,                                 makeDynString(sOpcUaSubscription),
              sOpcUaServerRedundant       + &quot;.Config.Subscriptions&quot;,                                 makeDynString(sOpcUaSubscriptionRedundant)) != 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error configuring subscription settings from: &quot; + sOpcUaSubscriptionSettings, &quot;&quot;);
      return FALSE;
    }
    else
    {
      deError = getLastError();
      if( dynlen(deError) &gt; 0 )
      {
        fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error configuring subscription settings from: &quot; + sOpcUaSubscriptionSettings + &quot;, due to: &quot; + getErrorText(), &quot;&quot;);
        return FALSE;
      }

      dpSetDescription(sOpcUaSubscription          + &quot;.&quot;, sDescription);
      dpSetDescription(sOpcUaSubscriptionRedundant + &quot;.&quot;, sDescription);
    }
  }


  return TRUE;
}





bool createDp(string sDp, string sDpt, dyn_string &amp;exceptionInfo)
{
  int iRes;
  dyn_errClass deError;


  if( dpExists(sDp) == FALSE )
  {
    iRes = dpCreate(sDp, sDpt);
    if( iRes != 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, creating DP: &quot; + sDp + &quot; of type: &quot; + sDpt, &quot;&quot;);
      fwExceptionHandling_display(exceptionInfo);
      return FALSE;
    }
    else
    {
      deError = getLastError();
      if( dynlen(deError) &gt; 0 )
      {
        fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, creating DP: &quot; + sDp + &quot; of type: &quot; + sDpt + &quot;, due to: &quot; + getErrorText(deError) , &quot;&quot;);
        fwExceptionHandling_display(exceptionInfo);
        return FALSE;
      }
    }
  }

  return TRUE;
}






bool CreateManagers(int iDriverNumber, dyn_string &amp;exceptionInfo)
{
  bool bOpcUaExists, bSimulatorExists, bIsRunning;
  int iLoop, iLen, iRes;
  dyn_dyn_mixed ddmAllManagers;


  iRes = fwInstallationManager_getAllInfoFromPvss(ddmAllManagers);
  if( iRes != 0 )
  {
    fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, Creating OPCUA and simulator manager for driver &quot; + iDriverNumber + &quot; -&gt; Error getting all project managers&quot;, &quot;&quot;);
    return FALSE;
  }
  else
  {
    iLen = dynlen(ddmAllManagers);
  }


  // Check if OPCUA -num iDriverNumber and simulator exists
  for( iLoop = 1 ; iLoop &lt;= iLen ; iLoop++ )
  {
    // Check if simulator is already defined
    if( (ddmAllManagers[iLoop][1] == &quot;WCCILsim&quot;)              &amp;&amp;
        (ddmAllManagers[iLoop][6] == &quot;-num &quot; + iDriverNumber) )
    {
      bSimulatorExists = TRUE;
    }

    // Check if OPC UA client is already defined
    if( (ddmAllManagers[iLoop][1] == &quot;WCCOAopcua&quot;)              &amp;&amp;
        (ddmAllManagers[iLoop][6] == &quot;-num &quot; + iDriverNumber) )
    {
      bOpcUaExists = TRUE;
    }
  }


  // Create OPC UA manager if doesn't exist
  if( !bOpcUaExists )
  {
    iRes = fwInstallationManager_add(&quot;WCCOAopcua&quot;, &quot;manual&quot;, 30, 5, 3, &quot;-num &quot; + iDriverNumber, &quot;&quot;);
    if( iRes == 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, Creating OPCUA manager for driver &quot; + iDriverNumber + &quot; -&gt; failed in calling fwInstallationManager_add&quot;, &quot;&quot;);
      return FALSE;
    }
  }
  else
  {
    // Change OPC UA manager to manual
    if( fwInstallationManager_setMode(&quot;WCCOAopcua&quot;, &quot;-num &quot; + iDriverNumber, &quot;manual&quot;, &quot;&quot;) != 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, Creating OPCUA manager for driver &quot; + iDriverNumber + &quot; -&gt; failed to change to manual WCCOAopcua -num &quot; + iDriverNumber + &quot; manager to manual&quot;, &quot;&quot;);
      return FALSE;
    }
    else
    {
      // Stop the OPC UA manager
      if( fwInstallationManager_command(&quot;STOP&quot;, &quot;WCCOAopcua&quot;, &quot;-num &quot; + iDriverNumber, &quot;&quot;) != 0 )
      {
        fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, Creating OPCUA manager for driver &quot; + iDriverNumber + &quot; -&gt; failed to stop the WCCOAopcua -num &quot; + iDriverNumber + &quot; manager&quot;, &quot;&quot;);
        return FALSE;
      }
    }
  }


  // Create simulator manager if doesn't exist
  if( !bSimulatorExists )
  {
    iRes = fwInstallationManager_add(&quot;WCCILsim&quot;, &quot;always&quot;, 30, 5, 3, &quot;-num &quot; + iDriverNumber, &quot;&quot;);
    if( iRes == 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, Creating Simulation manager for driver &quot; + iDriverNumber + &quot; -&gt; failed in calling fwInstallationManager_add&quot;, &quot;&quot;);
      return FALSE;
    }
  }
  else
  {
    // Check if manager is running
    if( fwInstallationManager_isRunning(&quot;WCCILsim&quot;, &quot;-num &quot; + iDriverNumber, bIsRunning, &quot;&quot;) != 0 )
    {
      fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, Creating Simulation manager for driver &quot; + iDriverNumber + &quot; -&gt; Error getting current status of the manager&quot;, &quot;&quot;);
      return FALSE;
    }

    if( !bIsRunning )
    {
      if( fwInstallationManager_restart(&quot;WCCILsim&quot;, &quot;-num &quot; + iDriverNumber, &quot;&quot;) != 0 )
      {
        fwException_raise(exceptionInfo, &quot;ERROR&quot;, &quot;Error, Creating Simulation manager for driver &quot; + iDriverNumber + &quot; -&gt; Error restarting manager WCCILsim -num &quot; + iDriverNumber, &quot;&quot;);
        return FALSE;
      }
    }
  }

  return TRUE;

}// CreateManagers()
]]></script>
