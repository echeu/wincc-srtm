  <script name="ScopeLib" isEscaped="1"><![CDATA[/**
  (c) Copyright CERN 2005. All rights not expressly granted are reserved.
  icecontrols.support@cern.ch

  SPDX-License-Identifier: LGPL-3.0-only
**/

string g_oldPwd;
string g_lastUserName;


string getTextFieldPasswordEncrypted(){
    //The Password widget may contain an ecrypted or crypted password depending on what the user has done:
    //a) if he has not modified the content it contains an encrypted pass and in this case g_oldPwd == Password.text
    //b) the user has modified the text, it will contain a clear password
    if(g_oldPwd == Password.text){ // User has not modified the password, it is already encrypted
        return g_oldPwd;
    } // else // User entered a new password (clear text)
    return rdbEncryptPassword(Password.text); //Re-write password in encrypted form
}

void openPopupMessage(string popupSummary, string popupText){
    ChildPanelOnCentralModal(&quot;vision/MessageInfo1&quot;, popupSummary, makeDynString(&quot;$1:&quot; + popupText));
}

void askUserAndExecuteDbAgentRestart(){
    dyn_float df;
    dyn_string ds;
    string message = &quot;DB connection parameters have changed. \nThe DB agent needs to be restarted. Proceed?&quot;;
    ChildPanelOnCentralReturn(&quot;fwInstallation/fwInstallation_messageInfo.pnl&quot;,
                              &quot;Changed parameters ...&quot;,
                              makeDynString(&quot;$text:&quot; + message, &quot;$help:fwInstallation/fwInstallation_systemStaticInfoDB.html&quot;),
                              df, ds);

    if(df.isEmpty() || df.first() &lt; 1.0){
        return;
    }

    openProgressBar(&quot;Sending restart command to manager.&quot;, &quot;&quot;,&quot;Sending restart command to manager.&quot;,
                    &quot;Please wait...&quot;, &quot;&quot;, &quot;&quot;, 0);

    string host = eventHost()[myReduHostNum()];
    int err = fwInstallationManager_command(&quot;RESTART&quot;, &quot;WCCOActrl&quot;, FW_INSTALLATION_DB_AGENT_MANAGER_CMD,
                                            host, pmonPort());
    closeProgressBar();

    if(err != 0){
        openPopupMessage(&quot;ERROR&quot;, &quot;Error when restarting the manager.&quot;);
    }else{
        openPopupMessage(&quot;INFO&quot;, &quot;Restart command sent to the manager.&quot;);
    }
}
]]></script>
  <script name="Initialize" isEscaped="1"><![CDATA[main()
{
    EnableAll(false);
    PopulatePanel();
    EnableAll(true);

    // Set focus to the first text field
    setInputFocus(myModuleName(), myPanelName(), &quot;Server&quot;);
}

void PopulatePanel(){
    string agentDp = fwInstallation_getAgentDp();
    if(!dpExists(agentDp)){
        return;
    }

    string server, username, password, owner;
    dpGet(agentDp + &quot;.db.connection.server&quot;, server,
          agentDp + &quot;.db.connection.username&quot;, username,
          agentDp + &quot;.db.connection.password&quot;, password,
          agentDp + &quot;.db.connection.schemaOwner&quot;, owner);

    UserName.text = username;
    g_lastUserName = username;

    Password.text = password;
    g_oldPwd = password;

    Server.text = server;
    tfOwner.text = owner;
}

void EnableAll(bool enabled){
    OKButton.enabled = enabled;

    Server.enabled = enabled;
    UserName.enabled = enabled;
    Password.enabled = enabled;
    tfOwner.enabled = enabled;
    Connect.enabled = enabled;
}
]]></script>
 </events>
