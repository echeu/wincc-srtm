  <shape Name="Connect" shapeType="PUSH_BUTTON" layerId="0">
   <properties>
    <prop name="serialId">57</prop>
    <prop name="Type"></prop>
    <prop name="RefPoint">96.5 265</prop>
    <prop name="Enable">True</prop>
    <prop name="Visible">True</prop>
    <prop name="ForeColor">_ButtonText</prop>
    <prop name="BackColor">_Button</prop>
    <prop name="TabOrder">9</prop>
    <prop name="ToolTipText">
     <prop name="en_US.utf8">Perform test connection to check if given DB credentials are correct. Hotkey: Ctrl+T</prop>
    </prop>
    <prop name="Hotkey">Ctrl+T</prop>
    <prop name="layoutAlignment">AlignCenter</prop>
    <prop name="snapMode">Point</prop>
    <prop name="Font">
     <prop name="en_US.utf8">Arial,-1,13,5,50,0,0,0,0,0</prop>
    </prop>
    <prop name="Location">90.5 190</prop>
    <prop name="Size">120 25</prop>
    <prop name="BorderStyle">Normal</prop>
    <prop name="Text">
     <prop name="en_US.utf8">Test connection</prop>
    </prop>
   </properties>
   <events>
    <script name="Clicked" isEscaped="1"><![CDATA[main()
{
    string encPwd = getTextFieldPasswordEncrypted();

    // Close the old connection before trying to open the new one
    fwInstallationDB_closeDBConnection();

    int connStatus = fwInstallationDB_openDBConnection(Server.text, UserName.text, encPwd, tfOwner.text);
    if(connStatus != 0){
        openPopupMessage(&quot;Connection Failed&quot;,
                         &quot;Database connection failed.\nCheck connection parameters.&quot;);
    }else{
        openPopupMessage(&quot;Connection OK&quot;,
                         &quot;Database connection successful.&quot;);
    }
}
]]></script>
   </events>
  </shape>
  <shape Name="OKButton" shapeType="PUSH_BUTTON" layerId="0">
   <properties>
    <prop name="serialId">33</prop>
    <prop name="Type"></prop>
    <prop name="RefPoint">133 238</prop>
    <prop name="Enable">True</prop>
    <prop name="Visible">True</prop>
    <prop name="ForeColor">_ButtonText</prop>
    <prop name="BackColor">_Button</prop>
    <prop name="TabOrder">10</prop>
    <prop name="ToolTipText">
     <prop name="en_US.utf8"></prop>
    </prop>
    <prop name="layoutAlignment">AlignCenter</prop>
    <prop name="snapMode">Point</prop>
    <prop name="Font">
     <prop name="en_US.utf8">Arial,-1,13,5,50,0,0,0,0,0</prop>
    </prop>
    <prop name="Location">135 240</prop>
    <prop name="Size">75 25</prop>
    <prop name="BorderStyle">Normal</prop>
    <prop name="Text">
     <prop name="en_US.utf8">OK</prop>
    </prop>
   </properties>
   <events>
    <script name="Clicked" isEscaped="1"><![CDATA[main()
{
    string agentDp = fwInstallation_getAgentDp();
    if(!dpExists(agentDp + &quot;.db.connection&quot;)){
        return;
    }

    fwInstallationDB_closeDBConnection();

    dyn_string connParamDpes = makeDynString(
            agentDp + &quot;.db.connection.server&quot;,
            agentDp + &quot;.db.connection.username&quot;,
            agentDp + &quot;.db.connection.schemaOwner&quot;);
    dyn_string connParamVals = makeDynString(
            Server.text,
            UserName.text,
            tfOwner.text);

    string encryptedPassword = getTextFieldPasswordEncrypted();
    if(g_oldPwd != encryptedPassword){ //Save new password in encrypted form only if it has changed
        connParamDpes.append(agentDp + &quot;.db.connection.password&quot;);
        connParamVals.append(encryptedPassword);
    }

    dpSetWait(connParamDpes, connParamVals);

    fwInstallationDB_setInitialized(true);
    fwInstallationDB_setUseDB(true);

    askUserAndExecuteDbAgentRestart();

    PanelOffReturn(makeDynFloat(1.0), makeDynString(&quot;OK&quot;));
}

]]></script>
   </events>
