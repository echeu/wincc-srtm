void EP_setInvalid()
{
  dyn_errClass err;

  if( !dpExists( \"dist_1:FF11_uptime.:_online.._invalid\"))
  {
    setValue(\"\", \"color\", \"_dpdoesnotexist\");
    return;
  }

  dpConnect(\"EP_setInvalidCB\",
            \"dist_1:FF11_uptime.:_online.._invalid\");
  err = getLastError();
  if (dynlen(err) > 0)
    setValue(\"\", \"color\", \"_dpdoesnotexist\");

}

void EP_setInvalidCB(string dp, bool boInvalid)
{
  setValue(\"\", \"color\", (boInvalid ? \"_invalid\" : \"\"));
}

void EP_setEnabled()
{
  dyn_errClass err;

  if( !dpExists( \"dist_1:SRTM.Zynq_ps_temp:_online.._value\"))
  {
    setValue(\"\", \"color\", \"_dpdoesnotexist\");
    return;
  }

  dpConnect(\"EP_setEnabledCB\",
            \"dist_1:SRTM.Zynq_ps_temp:_online.._value\");
  err = getLastError();
  if (dynlen(err) > 0)
    setValue(\"\", \"color\", \"_dpdoesnotexist\");

}

void EP_setEnabledCB(string dp, float fNewValue)
{
  setValue(\"\", \"enabled\",
           !(fNewValue < -100));
}

